# Node modules - never commit these
node_modules/

# Android build files - generated, don't commit
android/build/
android/.gradle/
android/app/build/
android/captures/
android/.idea/
*.iml

# iOS build files (future)
ios/App/Pods/
ios/App/App.xcworkspace/

# Environment and config files with secrets
.env
config.js
*.keystore
*.jks

# OS files
.DS_Store
Thumbs.db

# IDE / editor configs
.idea/
.vscode/

# Claude Code local state (plans, memory, conversation logs)
.claude/

# Capacitor temporary files
dist/
